# CERN SSO Authentication Configuration
# Get these credentials from CERN Application Portal: https://application-portal.web.cern.ch

# Required for accessing restricted CDS content
CERN_CLIENT_ID=your-client-id-here
CERN_CLIENT_SECRET=your-client-secret-here

# Optional: Override default endpoints (usually not needed)
# CERN_TOKEN_ENDPOINT=https://auth.cern.ch/auth/realms/cern/api-access/token
# CERN_JWKS_ENDPOINT=https://auth.cern.ch/auth/realms/cern/protocol/openid-connect/certs
# CERN_AUDIENCE=cds-api
